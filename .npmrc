# Speed up installs by caching the package store
cache-folder=.npm-cache

# Skip optional deps that don't apply (speeds up CI/CD)
omit=optional

# Avoid unnecessary audit/fund output in CI
audit=false
fund=false

# Force npm to resolve packages for all platforms when generating package-lock.json
# This prevents the Windows-only binary problem on Linux Docker builds
os=linux
cpu=x64
